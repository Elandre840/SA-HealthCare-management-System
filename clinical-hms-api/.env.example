PROJECT_NAME="Clinical HMS API"
ENVIRONMENT="local"

# PostgreSQL (used when running via Docker Compose)
POSTGRES_USER="clinic_user"
POSTGRES_PASSWORD="clinic_password"
POSTGRES_DB="clinical_hms"
DATABASE_URL="postgresql+psycopg://clinic_user:clinic_password@postgres:5432/clinical_hms"

# Redis (refresh-token revocation; required in Docker Compose)
REDIS_URL="redis://redis:6379/0"

SECRET_KEY="change-this-development-secret"
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=7
